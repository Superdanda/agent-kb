# =================== dev 开发环境配置 (默认) ===================
# MySQL 数据库 (本地)
DATABASE_URL=mysql+pymysql://hermes_kb:hermes_kb@172.25.80.1:3306/agent-platform

# MinIO 对象存储 (本地开发)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=hermes-kb-dev

# 应用配置
SECRET_KEY=hermes-dev-secret-key-do-not-use-in-production
STORAGE_TYPE=LOCAL
LOCAL_STORAGE_PATH=./data/uploads

# 环境标识
ENVIRONMENT=dev
HMAC_TIME_WINDOW_SECONDS=300
UPLOAD_MAX_SIZE_MB=50
