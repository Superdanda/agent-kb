# =================== local_prod 环境配置 ===================
# MySQL 数据库 (192.168.31.195)
DATABASE_URL=mysql+pymysql://12345678:12345678@192.168.31.195:3306/12345678

# MinIO 对象存储 (192.168.31.195:9090)
MINIO_ENDPOINT=192.168.31.195:9090
MINIO_ACCESS_KEY=echo
MINIO_SECRET_KEY=12345678
MINIO_BUCKET=hermes-kb

# 应用配置
SECRET_KEY=hermes-local-prod-secret-key-change-in-production
STORAGE_TYPE=MINIO
LOCAL_STORAGE_PATH=./data/uploads

# 环境标识
ENVIRONMENT=local_prod
HMAC_TIME_WINDOW_SECONDS=300
UPLOAD_MAX_SIZE_MB=50

# AI / LLM 配置 (任务 AI 对话功能)
AI_PROVIDER=anthropic
AI_BASE_URL=https://api.anthropic.com
AI_API_KEY=
AI_MODEL=claude-sonnet-4-5
AI_TASK_MODEL=
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.2
AI_STREAM_ENABLED=true
